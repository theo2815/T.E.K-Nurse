# T.E.K Nurse — environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. NEVER commit secrets.

# --- Supabase (client-safe) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (server-only — NEVER expose to the client) ---
# Use only inside app/api/* route handlers or server actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Email ---
# Supabase Auth's verification + reset emails are sent via the SMTP server
# configured in the Supabase Dashboard (Authentication → SMTP Settings).
# For T.E.K Nurse v1: Brevo (smtp-relay.brevo.com:587) with verified sender
# t.e.k.nurse.support@gmail.com. No env vars needed here in Phase 2.
# Phase 8 transactional worker may add BREVO_SMTP_KEY here.

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
