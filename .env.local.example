# T.E.K Nurse — environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. NEVER commit secrets.

# --- Supabase (client-safe) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (server-only — NEVER expose to the client) ---
# Use only inside app/api/* route handlers or server actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Email: Brevo SMTP (Phase 8c worker) ---
# Find these under: Brevo dashboard → top-right profile menu → SMTP & API → SMTP tab.
# SMTP_USER is the "Login" value (NOT your Brevo account email; it looks like
# XXXXXXXXX@smtp-brevo.com). SMTP_PASS is the active SMTP key value from the
# "Your SMTP Keys" table on the same page.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login@smtp-brevo.com
SMTP_PASS=your-brevo-smtp-key

# EMAIL_FROM must use a sender verified under Brevo → Senders, Domains &
# Dedicated IPs → Senders tab. Format: "Display Name <email@addr>".
EMAIL_FROM="T.E.K Nurse <t.e.k.nurse.support@gmail.com>"

# --- Email: dev safety guardrail ---
# Comma-separated list. When NODE_ENV !== "production" the worker rewrites
# every outbound To: address to the FIRST entry below, prefixes the subject
# with [DEV → original@addr], and stamps an X-Original-To header. This
# prevents real students/staff from receiving test emails during local dev.
# In production this list is ignored — emails go to their real recipients.
EMAIL_DEV_ALLOWLIST=t.e.k.nurse.support@gmail.com

# --- Cron worker ---
# Shared secret between Supabase pg_cron and POST /api/email/drain.
# Generate a fresh value with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then ALSO store the SAME value in Supabase Vault so pg_cron can read it
# (run once in the Supabase SQL editor):
#   select vault.create_secret(
#     'paste-the-same-value-here',
#     'tek_cron_secret',
#     'Bearer token for pg_cron → /api/email/drain'
#   );
CRON_SECRET=replace-me-with-64-hex-chars

# --- App ---
# Base URL the app is served from. Used by the QR generator (Phase 6) to
# build the URL embedded in each printed QR code: ${NEXT_PUBLIC_APP_URL}/s/{qr}
# and by Phase 8b email templates for absolute CTA links.
# Local dev: http://localhost:3000
# Production:  https://teknurse.vercel.app
# IMPORTANT: physically printed QR cards encode whatever value is set here at
# build time. Always set this to the production URL before printing cards.
NEXT_PUBLIC_APP_URL=https://teknurse.vercel.app
